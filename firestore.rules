rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserData() {
      try {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      } catch(e) {
        return null;
      }
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData() != null && getUserData().role == role;
    }
    
    function hasAnyRole(roles) {
      return isAuthenticated() && getUserData() != null && getUserData().role in roles;
    }
    
    function belongsToFacility(facilityId) {
      return isAuthenticated() && getUserData() != null && getUserData().assignedFacilityId == facilityId;
    }
    
    function isSessionValid() {
      let userDoc = getUserData();
      return isAuthenticated() && userDoc != null && 
             userDoc.phoneVerified == true &&
             userDoc.phoneVerified != null;
    }
    
    // Define staff roles that manage healthcare operations
    function isHealthcareStaff() {
      let userRole = getUserData().role;
      return hasAnyRole(['doctor', 'pharmacy', 'lab', 'maternity', 'chw', 'hospital_admin', 'super_admin']);
    }
    
    // Define patient/refugee roles
    function isPatient() {
      return hasAnyRole(['refugee', 'patient']);
    }
    
    // Rate limiting helper (simple check - in production use Cloud Functions)
    function isRateLimited() {
      return false; // Implement in Cloud Functions for better control
    }
    
    // =========================================================================
    // USERS COLLECTION - Profile Management
    // =========================================================================
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId) || hasRole('super_admin');
      
      // New user registration (create account)
      allow create: if isOwner(userId) && 
                       request.resource.data.phone != null &&
                       request.resource.data.phone != '' &&
                       request.resource.data.role != null &&
                       request.resource.data.phoneVerified != null;
      
      // Users update own profile (except role, facility assignment, verified status)
      allow update: if isOwner(userId) && 
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'assignedFacilityId', 'phoneVerified', 'uid'])
                    || hasRole('super_admin')
                    || hasRole('hospital_admin');
      
      // Only super_admin can delete users
      allow delete: if hasRole('super_admin');
    }
    
    // =========================================================================
    // SESSION MANAGEMENT
    // =========================================================================
    match /sessions/{sessionId} {
      // Users can read their own sessions
      allow read: if resource.data.userId == request.auth.uid || hasRole('super_admin');
      
      // System creates sessions (via Cloud Function or auth service)
      allow create: if request.auth != null;
      
      // Users can update their own sessions (mark as inactive)
      allow update: if resource.data.userId == request.auth.uid && 
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'role', 'createdAt']);
      
      // Admin can manage sessions
      allow delete: if hasRole('super_admin');
    }
    
    // =========================================================================
    // HEALTH FACILITIES (Hospitals, Clinics, Health Centers)
    // =========================================================================
    match /health_facilities/{facilityId} {
      // All authenticated users can read facilities (for facility selection and map)
      allow read: if isAuthenticated();
      
      // Only super_admin can create/edit facilities
      allow write: if hasRole('super_admin');
      
      allow delete: if hasRole('super_admin');
    }
    
    // =========================================================================
    // REFUGEE QUEUE SYSTEM - Multi-facility support
    // =========================================================================
    match /refugee_queue_system/{document=**} {
      
      // ─── INCOMING QUEUE (Doctor's Queue) ───
      match /queues/incoming/{queueId} {
        // Patients can read their own queue entries
        // Healthcare staff (doctors, CHWs, admins) can read all
        allow read: if isAuthenticated() && (
          resource.data.patientId == request.auth.uid ||
          isHealthcareStaff()
        );
        
        // Patients can create queue entries (join queue)
        allow create: if isAuthenticated() && 
                         request.resource.data.patientId == request.auth.uid &&
                         request.resource.data.facilityId != null &&
                         request.resource.data.status == 'waiting';
        
        // Healthcare staff can update queue entries
        allow update: if isHealthcareStaff() &&
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['patientId', 'facilityId']);
        
        // Only admins can delete
        allow delete: if hasAnyRole(['hospital_admin', 'super_admin']);
      }
      
      // ─── TRIAGE ASSESSMENTS (CHW & Healthcare Staff) ───
      match /triage_assessments/{assessmentId} {
        // Patients can read assessments performed on them
        // CHWs and healthcare staff can read assessments
        allow read: if isAuthenticated() && (
          resource.data.patientId == request.auth.uid ||
          isHealthcareStaff()
        );
        
        // CHWs and doctors can create triage assessments
        allow create: if hasAnyRole(['chw', 'doctor', 'hospital_admin', 'super_admin']) &&
                         request.resource.data.patientId != null &&
                         request.resource.data.chwId != null &&
                         request.resource.data.facilityId != null &&
                         request.resource.data.priority in ['critical', 'high', 'medium', 'low'];
        
        // Only the CHW who created it or healthcare staff can update
        allow update: if (resource.data.chwId == request.auth.uid || isHealthcareStaff()) &&
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['patientId', 'chwId', 'assessmentTime']);
        
        allow delete: if hasAnyRole(['hospital_admin', 'super_admin']);
      }
      
      // ─── PHARMACY QUEUE ───
      match /queues/pharmacy/{queueId} {
        allow read: if isAuthenticated() && (
          resource.data.patientId == request.auth.uid ||
          isHealthcareStaff()
        );
        
        allow create: if hasAnyRole(['doctor', 'chw', 'hospital_admin', 'super_admin']);
        
        allow update: if isHealthcareStaff();
        
        allow delete: if hasAnyRole(['hospital_admin', 'super_admin']);
      }
      
      // ─── LAB QUEUE ───
      match /queues/lab/{queueId} {
        allow read: if isAuthenticated() && (
          resource.data.patientId == request.auth.uid ||
          isHealthcareStaff()
        );
        
        allow create: if hasAnyRole(['doctor', 'chw', 'hospital_admin', 'super_admin']);
        
        allow update: if isHealthcareStaff();
        
        allow delete: if hasAnyRole(['hospital_admin', 'super_admin']);
      }
      
      // ─── MATERNITY QUEUE ───
      match /queues/maternity/{queueId} {
        allow read: if isAuthenticated() && (
          resource.data.patientId == request.auth.uid ||
          isHealthcareStaff()
        );
        
        allow create: if hasAnyRole(['doctor', 'chw', 'hospital_admin', 'super_admin']);
        
        allow update: if isHealthcareStaff();
        
        allow delete: if hasAnyRole(['hospital_admin', 'super_admin']);
      }
      
      // ─── PATIENT PROFILES ───
      match /patients/profiles/{patientId} {
        allow read: if isOwner(patientId) || isHealthcareStaff();
        
        allow create: if isOwner(patientId) || isHealthcareStaff();
        
        allow update: if isOwner(patientId) || isHealthcareStaff();
        
        allow delete: if hasAnyRole(['hospital_admin', 'super_admin']);
      }
    }
    
    // =========================================================================
    // PRESCRIPTIONS - Doctor Issued
    // =========================================================================
    match /prescriptions/{prescriptionId} {
      // Patients can read prescriptions issued to them
      // Healthcare staff can read relevant prescriptions
      allow read: if isAuthenticated() && (
        resource.data.patientId == request.auth.uid ||
        isHealthcareStaff()
      );
      
      // Only doctors can create prescriptions
      allow create: if hasRole('doctor') &&
                       request.resource.data.patientId != null &&
                       request.resource.data.doctorId == request.auth.uid &&
                       request.resource.data.status == 'active';
      
      // Doctors can update their own prescriptions, pharmacy can mark as fulfilled
      allow update: if (resource.data.doctorId == request.auth.uid && hasRole('doctor')) ||
                       (hasRole('pharmacy') && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      
      // Only admins can delete
      allow delete: if hasAnyRole(['hospital_admin', 'super_admin']);
    }
    
    // =========================================================================
    // LAB REQUESTS & RESULTS
    // =========================================================================
    match /lab_requests/{requestId} {
      // Patients can read their own lab requests
      // Lab staff and doctors can read relevant requests
      allow read: if isAuthenticated() && (
        resource.data.patientId == request.auth.uid ||
        hasAnyRole(['lab', 'doctor', 'hospital_admin', 'super_admin'])
      );
      
      // Only doctors can request labs
      allow create: if hasRole('doctor') &&
                       request.resource.data.patientId != null &&
                       request.resource.data.doctorId == request.auth.uid;
      
      // Lab staff and doctors can update
      allow update: if hasAnyRole(['lab', 'doctor', 'hospital_admin', 'super_admin']);
      
      // Only admins can delete
      allow delete: if hasAnyRole(['hospital_admin', 'super_admin']);
    }
    
    // =========================================================================
    // AMBULANCE SYSTEM - Emergency Services
    // =========================================================================
    match /ambulance_requests/{requestId} {
      // Patients can read their own requests
      // Ambulance drivers and staff can read all active requests
      allow read: if isAuthenticated() && (
        resource.data.patientId == request.auth.uid ||
        hasAnyRole(['ambulance_driver', 'hospital_admin', 'super_admin'])
      );
      
      // Any authenticated user can request ambulance (emergency)
      allow create: if isAuthenticated() &&
                       request.resource.data.patientId == request.auth.uid &&
                       request.resource.data.status == 'pending';
      
      // Ambulance drivers and staff can update status and location
      allow update: if hasAnyRole(['ambulance_driver', 'hospital_admin', 'super_admin']);
      
      // Only admins can delete
      allow delete: if hasAnyRole(['hospital_admin', 'super_admin']);
    }
    
    match /ambulances/{ambulanceId} {
      // All authenticated users can read ambulance locations
      allow read: if isAuthenticated();
      
      // Ambulance drivers can update their vehicle location and status
      allow update: if hasAnyRole(['ambulance_driver', 'hospital_admin', 'super_admin']);
      
      // Only admins can write initial data or delete
      allow write: if hasAnyRole(['hospital_admin', 'super_admin']);
    }
    
    // =========================================================================
    // ANALYTICS - Read-only for staff
    // =========================================================================
    match /analytics/{document=**} {
      // Healthcare staff can read analytics
      allow read: if isHealthcareStaff();
      
      // Writes should be done via Cloud Functions (trusted environment)
      allow write: if false; // Disable direct writes from client
    }
    
    // =========================================================================
    // AUDIT LOGS - Security and Compliance
    // =========================================================================
    match /audit_logs/{logId} {
      // Only super_admin can read audit logs
      allow read: if hasRole('super_admin');
      
      // Writes via Cloud Function only (trusted environment)
      allow create: if request.auth != null; // Allow auth service to write
      
      allow write: if false; // No direct updates
    }
    
    // =========================================================================
    // SETTINGS & CONFIGURATION
    // =========================================================================
    match /settings/{document=**} {
      // All authenticated users can read settings
      allow read: if isAuthenticated();
      
      // Only super_admin can write settings
      allow write: if hasRole('super_admin');
    }
    
  }
}
